# .env.example — Verdict Watch
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is listed in .gitignore.

# ── GOOGLE GEMINI (primary AI — Steps 0–3) ───────────────────
# Get free key at: aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── GROQ (fallback AI) ────────────────────────────────────────
# Get free key at: console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── VERTEX AI (enterprise governance — Steps 4+5) ────────────
# Optional — only needed for Cloud Run deployment
# Get your project ID at: console.cloud.google.com
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── DATABASE (optional — defaults to local SQLite) ────────────
DATABASE_URL=sqlite:///./verdict_watch.db