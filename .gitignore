
# =============================================================================
#  .gitignore — SkillForge AI Adaptive Onboarding Engine
# =============================================================================

# ── SECRETS (NEVER COMMIT) ───────────────────────────────────────────────────
.env
.env.*
*.env
secrets.json
config.secret.*

# ── PYTHON ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ── VIRTUAL ENVIRONMENTS ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env/
virtualenv/
.virtualenv/

# ── DISTRIBUTION / BUILD ─────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/

# ── TESTING ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ── JUPYTER ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── ML MODELS & LARGE FILES ──────────────────────────────────────────────────
*.pkl
*.pickle
*.h5
*.pt
*.pth
*.ckpt
*.bin
*.safetensors
models/
checkpoints/
sentence_transformers_cache/
.cache/

# ── GENERATED OUTPUT FILES ───────────────────────────────────────────────────
outputs/
exports/
skillforge_roadmap_*.pdf
onboarding_roadmap_*.pdf
*.pdf

# ── UPLOADED TEST FILES ──────────────────────────────────────────────────────
test_uploads/
sample_data/*.pdf
sample_data/*.docx
uploads/

# ── OS FILES ─────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ── EDITORS & IDEs ───────────────────────────────────────────────────────────
# VSCode
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ── LOGS ─────────────────────────────────────────────────────────────────────
*.log
logs/
log/
pip-log.txt
pip-delete-this-directory.txt

# ── NODE (if any frontend tooling added later) ───────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── DOCKER ───────────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ── DASH SPECIFIC ────────────────────────────────────────────────────────────
.dash_cache/
assets/.webassets-cache

# ── GITHUB CODESPACES ────────────────────────────────────────────────────────
.codespaces/
